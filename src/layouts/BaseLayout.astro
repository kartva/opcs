---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Optimizing Purdue CS",
  description = "~6000 word guide on things one can do while in Purdue CS."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
